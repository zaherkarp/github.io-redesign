<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>Zaher Karp, Writing</title>
    <link>{{ blog_url }}</link>
    <atom:link href="{{ feed_url }}" rel="self" type="application/rss+xml" />
    <description>Healthcare data engineering, Medicare Advantage analytics, and adjacent things.</description>
    <language>en-us</language>
    <lastBuildDate>{{ build_date_rfc822 }}</lastBuildDate>
    <generator>build_blog.py</generator>
    {% for post in posts %}
    <item>
      <title>{{ post.title | e }}</title>
      <link>{{ site_url }}/blog/{{ post.slug }}/?utm_source=rss&amp;utm_medium=feed</link>
      <guid isPermaLink="true">{{ site_url }}/blog/{{ post.slug }}/</guid>
      <pubDate>{{ post.publish_date_rfc822 }}</pubDate>
      <description>{{ post.description | e }}</description>
      {% for tag in post.tags %}<category>{{ tag | e }}</category>
      {% endfor %}
    </item>
    {% endfor %}
  </channel>
</rss>
